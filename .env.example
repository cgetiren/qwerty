# Frontend (Vite) — required for npm run dev
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Only for scripts/seed-local-admin.ts — never commit real keys; never expose in the browser.
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Database password (project creation password) — for npm run db:apply-migrations only.
# Dashboard → Project Settings → Database
SUPABASE_DB_PASSWORD=

# Or full Postgres URI instead of SUPABASE_DB_PASSWORD:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
